TELEGRAM_DB = G121_ROOT / "telegram.db"
TELEGRAM_MEDIA_DIR = G121_ROOT / "telegram-media"


def _telegram_creds() -> tuple[str, str]:
    """Read Telegram bot token + chat id from the merged env. Exits if either
    is missing so we never ship a hardcoded token again."""
    env = load_env()
    token = env.get("TELEGRAM_BOT_TOKEN")
    chat_id = env.get("TELEGRAM_CHAT_ID")
    if not token or not chat_id:
        console.print("[red]TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID must be set in ~/.envrc or .env[/red]")
        sys.exit(1)
    return token, chat_id


def init_telegram_db():
    """Initialize Telegram SQLite database."""
    import sqlite3
    conn = sqlite3.connect(TELEGRAM_DB)
    conn.execute('''
        CREATE TABLE IF NOT EXISTS updates (
            update_id INTEGER PRIMARY KEY,
            raw_json TEXT NOT NULL,
            message_id INTEGER,
            chat_id INTEGER,
            from_id INTEGER,
            from_name TEXT,
            date INTEGER,
            message_type TEXT,
            text_content TEXT,
            file_id TEXT,
            local_path TEXT,
            synced_at TEXT
        )
    ''')
    conn.execute('CREATE INDEX IF NOT EXISTS idx_date ON updates(date)')

    # Migration: add local_path column if it doesn't exist
    try:
        conn.execute('ALTER TABLE updates ADD COLUMN local_path TEXT')
    except sqlite3.OperationalError:
        pass  # Column already exists

    conn.commit()
    return conn


def download_telegram_file(file_id: str, message_type: str, date: int) -> str | None:
    """Download a file from Telegram and return local path."""
    import httpx

    token, _ = _telegram_creds()

    # Get file info
    response = httpx.get(
        f"https://api.telegram.org/bot{token}/getFile",
        params={"file_id": file_id},
        timeout=30,
    )
    result = response.json()
    if not result.get("ok"):
        console.print(f"[yellow]Could not get file info: {result}[/yellow]")
        return None

    file_path = result["result"].get("file_path")
    if not file_path:
        return None

    # Create media directory
    TELEGRAM_MEDIA_DIR.mkdir(exist_ok=True)

    # Determine extension from file_path
    ext = Path(file_path).suffix or {
        "voice": ".ogg",
        "photo": ".jpg",
        "sticker": ".webp",
        "document": "",
    }.get(message_type, "")

    # Create filename with date prefix
    dt = datetime.fromtimestamp(date) if date else datetime.now()
    filename = f"{dt.strftime('%Y%m%d-%H%M%S')}-{message_type}{ext}"
    local_path = TELEGRAM_MEDIA_DIR / filename

    # Download file
    file_url = f"https://api.telegram.org/file/bot{token}/{file_path}"
    response = httpx.get(file_url, timeout=60)
    if response.status_code == 200:
        local_path.write_bytes(response.content)
        return str(local_path)
    else:
        console.print(f"[yellow]Failed to download {file_url}[/yellow]")
        return None


def parse_update(update: dict) -> dict:
    """Extract fields from a Telegram update for indexing."""
    msg = update.get("message") or update.get("edited_message") or {}
    reaction = update.get("message_reaction")

    from_user = msg.get("from", {})
    chat = msg.get("chat", {})

    # Determine message type and content
    if "text" in msg:
        msg_type = "text"
        text_content = msg["text"]
        file_id = None
    elif "voice" in msg:
        msg_type = "voice"
        text_content = f"[Voice message, {msg['voice'].get('duration', 0)}s]"
        file_id = msg["voice"].get("file_id")
    elif "photo" in msg:
        msg_type = "photo"
        text_content = msg.get("caption", "[Photo]")
        # Get largest photo
        file_id = msg["photo"][-1].get("file_id") if msg["photo"] else None
    elif "document" in msg:
        msg_type = "document"
        text_content = msg.get("caption") or f"[Document: {msg['document'].get('file_name', 'unknown')}]"
        file_id = msg["document"].get("file_id")
    elif "sticker" in msg:
        msg_type = "sticker"
        text_content = f"[Sticker: {msg['sticker'].get('emoji', '')}]"
        file_id = msg["sticker"].get("file_id")
    elif reaction:
        msg_type = "reaction"
        emoji = reaction.get("new_reaction", [{}])[0].get("emoji", "")
        text_content = f"[Reaction: {emoji}]"
        file_id = None
        chat = reaction.get("chat", {})
        from_user = reaction.get("user", {})
    else:
        msg_type = "unknown"
        text_content = None
        file_id = None

    from_name = from_user.get("first_name", "")
    if from_user.get("last_name"):
        from_name += " " + from_user["last_name"]
    if from_user.get("is_bot"):
        from_name += " [bot]"

    return {
        "update_id": update["update_id"],
        "message_id": msg.get("message_id"),
        "chat_id": chat.get("id"),
        "from_id": from_user.get("id"),
        "from_name": from_name,
        "date": msg.get("date") or (reaction.get("date") if reaction else None),
        "message_type": msg_type,
        "text_content": text_content,
        "file_id": file_id,
    }


@cli.group()
def telegram():
    """Telegram operations (Barblebot)."""
    pass


@telegram.command("send")
@click.argument("message", nargs=-1, required=True)
def telegram_send(message):
    """Send a message via Telegram.

    Examples:
      life telegram send "Hello from the command line"
      life telegram send Bank balance is 9533 SEK
    """
    import json
    import httpx

    text = " ".join(message)

    token, chat_id = _telegram_creds()
    response = httpx.post(
        f"https://api.telegram.org/bot{token}/sendMessage",
        data={
            "chat_id": chat_id,
            "text": text,
            "parse_mode": "Markdown",
        },
    )

    result = response.json()
    if result.get("ok"):
        # Store the sent message in our database
        msg = result.get("result", {})
        conn = init_telegram_db()
        now = datetime.now().isoformat()

        # Use negative message_id as update_id for sent messages (to avoid conflicts)
        fake_update_id = -msg.get("message_id", 0)

        try:
            conn.execute('''
                INSERT INTO updates (update_id, raw_json, message_id, chat_id, from_id,
                                    from_name, date, message_type, text_content, file_id, synced_at)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            ''', (
                fake_update_id,
                json.dumps(result),
                msg.get("message_id"),
                msg.get("chat", {}).get("id"),
                msg.get("from", {}).get("id"),
                "Barblebot [bot]",
                msg.get("date"),
                "text",
                text,
                None,
                now,
            ))
            conn.commit()
        except Exception:
            pass  # Don't fail if DB write fails
        finally:
            conn.close()

        console.print("[green]Sent![/green]")
    else:
        console.print(f"[red]Error: {result}[/red]")


@telegram.command("sync")
def telegram_sync():
    """Sync recent messages from Telegram to local database."""
    import sqlite3
    import json
    import httpx

    conn = init_telegram_db()

    # Get the highest update_id we have
    row = conn.execute("SELECT MAX(update_id) FROM updates").fetchone()
    last_update_id = row[0] if row[0] else 0

    # Fetch new updates (offset = last_id + 1 to get only new ones)
    params = {"limit": 100, "allowed_updates": ["message", "edited_message", "message_reaction"]}
    if last_update_id:
        params["offset"] = last_update_id + 1

    token, _ = _telegram_creds()
    response = httpx.get(
        f"https://api.telegram.org/bot{token}/getUpdates",
        params=params,
        timeout=30,
    )

    result = response.json()
    if not result.get("ok"):
        console.print(f"[red]Error: {result}[/red]")
        return

    updates = result.get("result", [])
    if not updates:
        console.print("[dim]No new messages[/dim]")
        conn.close()
        return

    # Store each update
    now = datetime.now().isoformat()
    new_count = 0
    media_count = 0
    for update in updates:
        parsed = parse_update(update)

        # Download media if there's a file_id
        local_path = None
        if parsed["file_id"]:
            console.print(f"[dim]Downloading {parsed['message_type']}...[/dim]")
            local_path = download_telegram_file(
                parsed["file_id"],
                parsed["message_type"],
                parsed["date"]
            )
            if local_path:
                media_count += 1

        try:
            conn.execute('''
                INSERT INTO updates (update_id, raw_json, message_id, chat_id, from_id,
                                    from_name, date, message_type, text_content, file_id, local_path, synced_at)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            ''', (
                parsed["update_id"],
                json.dumps(update),  # Store full raw JSON
                parsed["message_id"],
                parsed["chat_id"],
                parsed["from_id"],
                parsed["from_name"],
                parsed["date"],
                parsed["message_type"],
                parsed["text_content"],
                parsed["file_id"],
                local_path,
                now,
            ))
            new_count += 1
        except sqlite3.IntegrityError:
            pass  # Already exists

    conn.commit()
    conn.close()
    msg = f"[green]Synced {new_count} new messages[/green]"
    if media_count:
        msg += f" [dim]({media_count} media files downloaded)[/dim]"
    console.print(msg)


