JOURNAL_FILE = G121_ROOT / "JOURNAL.md"
ENV_FILE = G121_ROOT / ".env"

console = Console()


def load_env() -> dict:
    """Merge process env with ~/.envrc and g121/.env (supports `export` prefix)."""
    env = os.environ.copy()
    for path in (Path.home() / ".envrc", ENV_FILE):
        if not path.exists():
            continue
        for raw in path.read_text().splitlines():
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            if line.startswith("export "):
                line = line[len("export "):]
            if "=" not in line:
                continue
            key, val = line.split("=", 1)
            env_for_expand = {**env, "HOME": env.get("HOME", str(Path.home()))}
            val = val.strip().strip('"').strip("'")
            val = os.path.expanduser(val)
            # Minimal $VAR / ${VAR} expansion using our merged env
            import re
            def _sub(m):
                k = m.group(1) or m.group(2)
                return env_for_expand.get(k, "")
            val = re.sub(r"\$\{([A-Z_][A-Z0-9_]*)\}|\$([A-Z_][A-Z0-9_]*)", _sub, val)
            env[key.strip()] = val
    return env


def run_frick(*args, capture=False):
    """Run the installed `frick` Go binary with --key-file from env."""
    env = load_env()
    cmd = ["frick"]
    key_file = env.get("FRICK_KEY_FILE")
    if key_file:
        cmd += ["--key-file", key_file]
    cmd += list(args)
    if capture:
        result = subprocess.run(cmd, env=env, capture_output=True, text=True)
        return result.stdout + result.stderr
    else:
        subprocess.run(cmd, env=env)


def run_gmail_sync(*args):
    """Run gmail-sync commands."""
    env = os.environ.copy()
    # Keep uv from complaining about an inherited VIRTUAL_ENV that points at
    # whichever cache lane the last `uv run ...` used — let the project's
    # .venv resolution take over.
    env.pop("VIRTUAL_ENV", None)
    cmd = ["uv", "run", "sync.py", *args]
    subprocess.run(cmd, cwd=GMAIL_DIR, env=env)


