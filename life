@mail.command("list")
@click.option("--limit", default=10, help="Number of messages to show")
def mail_list(limit):
    """List recent emails with their IDs (for use with reply)."""
    import sqlite3

    db_path = GMAIL_DIR / "gmail.db"
    if not db_path.exists():
        console.print("[red]Gmail database not found. Run 'life mail sync' first.[/red]")
        return

    conn = sqlite3.connect(db_path)
    rows = conn.execute(
        '''SELECT id, date, from_addr, subject
           FROM messages
           ORDER BY date DESC LIMIT ?''',
        (limit,)
    ).fetchall()
    conn.close()

    if not rows:
        console.print("[yellow]No messages found.[/yellow]")
        return

    table = Table(title="Recent Emails")
    table.add_column("ID (short)", style="cyan", no_wrap=True)
    table.add_column("Date", style="dim")
    table.add_column("From")
    table.add_column("Subject")

    for msg_id, date, from_addr, subject in rows:
        # Show short ID (first 8 chars) for usability
        short_id = msg_id[:8]
        from_short = from_addr[:35] + "..." if len(from_addr) > 35 else from_addr
        subj_short = subject[:40] + "..." if len(subject) > 40 else subject
        date_short = date[:16] if date else ""
        table.add_row(short_id, date_short, from_short, subj_short)

    console.print(table)
    console.print("\n[dim]Use 'life mail reply <ID>' to reply to a message[/dim]")


@mail.command("reply")
@click.argument("message_id")
@click.argument("body", required=False)
@click.option("--yes", "-y", is_flag=True, help="Skip confirmation prompt")
def mail_reply(message_id, body, yes):
    """Reply to an email by message ID.

    Use 'life mail list' or 'life mail search' to find message IDs.

    Examples:
      life mail reply 19bdb2f4 "Thanks for the info!"
      life mail reply 19bdb2f4 --yes "Send without confirmation"
    """
    import sqlite3

    db_path = GMAIL_DIR / "gmail.db"
    if not db_path.exists():
        console.print("[red]Gmail database not found. Run 'life mail sync' first.[/red]")
        return

    conn = sqlite3.connect(db_path)
    # Support both full ID and prefix match
    row = conn.execute(
        '''SELECT id, subject, from_addr, date
           FROM messages
           WHERE id = ? OR id LIKE ?
           ORDER BY date DESC LIMIT 1''',
        (message_id, f'{message_id}%')
    ).fetchone()

    if not row:
        console.print(f"[red]No message found with ID '{message_id}'[/red]")
        console.print("[dim]Use 'life mail list' to see recent messages with IDs[/dim]")
        return

    msg_id, subject, from_addr, date = row
    console.print(f"\n[bold]Replying to:[/bold]")
    console.print(f"  ID: [cyan]{msg_id[:8]}[/cyan]")
    console.print(f"  From: {from_addr}")
    console.print(f"  Subject: {subject}")
    console.print(f"  Date: {date}\n")

    if not body:
        console.print("[dim]Enter your reply (Ctrl+D when done):[/dim]")
        body = sys.stdin.read().strip()

    if not body:
        console.print("[yellow]Empty body, aborting.[/yellow]")
        return

    console.print("\n[bold]Message preview:[/bold]")
    console.print(f"[dim]{body[:500]}{'...' if len(body) > 500 else ''}[/dim]\n")

    if not yes and not click.confirm("Send this reply?"):
        console.print("[yellow]Cancelled.[/yellow]")
        return

    conn.close()
    run_gmail_sync("reply", msg_id, body)


