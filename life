@journal.command("add")
@click.argument("entry", required=False)
@click.option("--section", "-s", help="Section header (e.g., 'Gmail Setup')")
def journal_add(entry, section):
    """Add an entry to the journal.

    Examples:
      life journal add "Set up the life CLI tool"
      life journal add --section "Life CLI" "Created unified command interface"
    """
    if not entry:
        console.print("[dim]Enter journal entry (Ctrl+D when done):[/dim]")
        entry = sys.stdin.read().strip()

    if not entry:
        console.print("[yellow]Empty entry, aborting.[/yellow]")
        return

    today = datetime.now().strftime("%Y-%m-%d")

    content = JOURNAL_FILE.read_text() if JOURNAL_FILE.exists() else "# G121 Setup Journal\n"

    # Check if today's date section exists
    date_header = f"## {today}"
    if date_header not in content:
        # Add new date section after the title
        lines = content.split("\n")
        insert_idx = 2  # After title and blank line
        lines.insert(insert_idx, f"\n{date_header}\n")
        content = "\n".join(lines)

    # Find position to insert entry (after the date header)
    if section:
        new_entry = f"\n### {section}\n\n{entry}\n"
    else:
        new_entry = f"\n{entry}\n"

    # Insert after the date header
    date_pos = content.find(date_header)
    insert_pos = content.find("\n", date_pos) + 1

    # Skip past any existing content for today until we hit next date or section
    next_section = content.find("\n## ", insert_pos)
    if next_section == -1:
        next_section = len(content)

    content = content[:next_section] + new_entry + content[next_section:]

    JOURNAL_FILE.write_text(content)
    console.print(f"[green]Added to journal ({today})[/green]")


