@transcript.command("show")
@click.option("--hours", "-h", default=1.0, help="Hours of history to show")
@click.option("--timestamps/--no-timestamps", "-t", default=True, help="Show timestamps per line")
def transcript_show(hours, timestamps):
    """Show recent transcripts."""
    import redis

    r = redis.Redis(decode_responses=True)

    # Calculate time range
    now_ms = int(datetime.now().timestamp() * 1000)
    start_ms = int(now_ms - hours * 3600 * 1000)

    # Get entries from Redis stream
    try:
        entries = r.xrange("transcripts", f"{start_ms}-0", "+")
    except redis.ConnectionError:
        console.print("[red]Cannot connect to Redis. Is it running?[/red]")
        return

    if not entries:
        console.print(f"[yellow]No transcripts in the last {hours} hour(s)[/yellow]")
        return

    # Filter to final transcripts only
    finals = []
    for entry_id, fields in entries:
        if fields.get("is_final") == "1" and fields.get("transcript"):
            timestamp = fields.get("timestamp", "")
            text = fields.get("transcript", "")
            finals.append((timestamp, text))

    if not finals:
        console.print(f"[yellow]No final transcripts in the last {hours} hour(s)[/yellow]")
        return

    console.print(f"\n[bold]Transcripts (last {hours}h)[/bold]\n")

    for timestamp, text in finals:
        try:
            dt = datetime.fromisoformat(timestamp.replace("Z", "+00:00"))
            time_str = dt.strftime("%H:%M:%S")
        except:
            time_str = "??:??:??"

        if timestamps:
            console.print(f"[dim]{time_str}[/dim] {text}")
        else:
            console.print(f"  {text}")

    console.print(f"\n[dim]Total: {len(finals)} utterances[/dim]")


def mux_opus_to_ogg(opus_frames: list[bytes], sample_rate: int = 48000, channels: int = 2) -> bytes:
    """Mux raw Opus frames into an OggOpus container without re-encoding.

    This is FAST because it just adds Ogg page headers around existing Opus data.
    """
    import struct
    import zlib

    def ogg_crc32(data: bytes) -> int:
        # Ogg uses CRC32 with polynomial 0x04c11db7
        crc_table = []
        for i in range(256):
            crc = i << 24
            for _ in range(8):
                if crc & 0x80000000:
                    crc = ((crc << 1) ^ 0x04c11db7) & 0xffffffff
                else:
                    crc = (crc << 1) & 0xffffffff
            crc_table.append(crc)

        crc = 0
        for byte in data:
            crc = ((crc << 8) ^ crc_table[((crc >> 24) ^ byte) & 0xff]) & 0xffffffff
        return crc

    def make_page(granule: int, serial: int, page_seq: int, segments: list[bytes],
                  bos: bool = False, eos: bool = False) -> bytes:
        # Build segment table
        seg_table = b""
        for seg in segments:
            length = len(seg)
            while length >= 255:
                seg_table += bytes([255])
                length -= 255
            seg_table += bytes([length])

        header_type = (0x02 if bos else 0) | (0x04 if eos else 0)

        # Build header without CRC
        header = b"OggS"  # capture pattern
        header += bytes([0])  # version
        header += bytes([header_type])
        header += struct.pack("<Q", granule)  # granule position
        header += struct.pack("<I", serial)   # serial number
        header += struct.pack("<I", page_seq)  # page sequence
        header += struct.pack("<I", 0)  # CRC placeholder
        header += bytes([len(segments)])  # segment count
        header += seg_table

        page_data = b"".join(segments)
        full_page = header + page_data

        # Calculate and insert CRC
        crc = ogg_crc32(full_page)
        full_page = full_page[:22] + struct.pack("<I", crc) + full_page[26:]

        return full_page

    serial = 0x12345678  # arbitrary stream serial
    pages = []
    page_seq = 0

    # OpusHead (ID header)
    opus_head = b"OpusHead"
    opus_head += bytes([1])  # version
    opus_head += bytes([channels])
    opus_head += struct.pack("<H", 0)  # pre-skip
    opus_head += struct.pack("<I", sample_rate)  # input sample rate
    opus_head += struct.pack("<h", 0)  # output gain
    opus_head += bytes([0])  # channel mapping family

    pages.append(make_page(0, serial, page_seq, [opus_head], bos=True))
    page_seq += 1

    # OpusTags (comment header)
    vendor = b"life-cli"
    opus_tags = b"OpusTags"
    opus_tags += struct.pack("<I", len(vendor)) + vendor
    opus_tags += struct.pack("<I", 0)  # no user comments

    pages.append(make_page(0, serial, page_seq, [opus_tags]))
    page_seq += 1

    # Audio pages - pack multiple frames per page
    # Ogg page can have max 255 lacing values total
    # Each Opus frame ~100-300 bytes needs 1-2 lacing values
    # Use conservative limit of 50 frames per page (~100 lacing values)
    granule = 0
    samples_per_frame = 960  # 20ms at 48kHz
    current_segments = []
    max_frames_per_page = 50

    for i, frame in enumerate(opus_frames):
        is_last = (i == len(opus_frames) - 1)
        current_segments.append(frame)
        granule += samples_per_frame

        if len(current_segments) >= max_frames_per_page or is_last:
            pages.append(make_page(granule, serial, page_seq, current_segments, eos=is_last))
            page_seq += 1
            current_segments = []

    return b"".join(pages)


LAST_RETRANSCRIBE_FILE = Path.home() / "G121" / ".last-retranscribe"


def get_last_retranscribe_time() -> int | None:
    """Get timestamp (microseconds) of last retranscription."""
    if LAST_RETRANSCRIBE_FILE.exists():
        try:
            return int(LAST_RETRANSCRIBE_FILE.read_text().strip())
        except:
            pass
    return None


def set_last_retranscribe_time(timestamp_us: int):
    """Save timestamp of this retranscription."""
    LAST_RETRANSCRIBE_FILE.write_text(str(timestamp_us))


@transcript.command("retranscribe")
@click.option("--last", "last_minutes", type=float, help="Retranscribe last N minutes")
@click.option("--from", "from_time", help="Start time (HH:MM or HH:MM:SS)")
@click.option("--to", "to_time", help="End time (HH:MM or HH:MM:SS)")
@click.option("--since-last", "since_last", is_flag=True, help="Retranscribe since last retranscription")
def transcript_retranscribe(last_minutes, from_time, to_time, since_last):
    """Re-transcribe audio using Deepgram's batch API for better accuracy.

    Examples:
      life transcript retranscribe --last 5      Last 5 minutes
      life transcript retranscribe --from 17:25 --to 17:30
      life transcript retranscribe --since-last  Since last retranscription
    """
    import sqlite3
    import httpx

    ARCHIVE_DB = Path.home() / "G121" / "audio-archive.db"
    DEEPGRAM_API_KEY = os.environ.get("DEEPGRAM_API_KEY")

    if not DEEPGRAM_API_KEY:
        console.print("[red]DEEPGRAM_API_KEY not set[/red]")
        return

    if not ARCHIVE_DB.exists():
        console.print("[red]Audio archive not found at ~/G121/audio-archive.db[/red]")
        return

    # Calculate time range
    now = datetime.now()
    end_us = int(now.timestamp() * 1_000_000)

    if since_last:
        last_time = get_last_retranscribe_time()
        if last_time:
            start_us = last_time
            last_dt = datetime.fromtimestamp(last_time / 1_000_000)
            console.print(f"[dim]Since last retranscription: {last_dt.strftime('%H:%M:%S')}[/dim]")
        else:
            console.print("[yellow]No previous retranscription found, using last 5 minutes[/yellow]")
            start_us = int((now.timestamp() - 5 * 60) * 1_000_000)
    elif last_minutes:
        start_us = int((now.timestamp() - last_minutes * 60) * 1_000_000)
    elif from_time and to_time:
        # Parse times (assume today)
        today = now.strftime("%Y-%m-%d")
        try:
            start_dt = datetime.fromisoformat(f"{today}T{from_time}")
            end_dt = datetime.fromisoformat(f"{today}T{to_time}")
            start_us = int(start_dt.timestamp() * 1_000_000)
            end_us = int(end_dt.timestamp() * 1_000_000)
        except ValueError as e:
            console.print(f"[red]Invalid time format: {e}[/red]")
            return
    else:
        console.print("[red]Specify --last N, --from/--to times, or --since-last[/red]")
        return

    # Query packets
    conn = sqlite3.connect(ARCHIVE_DB)
    rows = conn.execute('''
        SELECT opus_data FROM opus_packets
        WHERE captured_at_us >= ? AND captured_at_us <= ?
        ORDER BY captured_at_us
    ''', (start_us, end_us)).fetchall()
    conn.close()

    if not rows:
        console.print("[yellow]No audio found in that time range[/yellow]")
        return

    duration_sec = len(rows) * 0.02  # 20ms per packet
    console.print(f"[dim]Found {len(rows)} packets ({duration_sec:.1f}s of audio)[/dim]")

    # Extract raw Opus frames
    opus_frames = [frame for (frame,) in rows]

    try:
        # Fast mux to OggOpus (no re-encoding!)
        console.print("[dim]Muxing to OggOpus (no re-encoding)...[/dim]")
        ogg_data = mux_opus_to_ogg(opus_frames)
        console.print(f"[dim]Created {len(ogg_data) / 1024:.1f}KB OggOpus[/dim]")

        # Send to Deepgram batch API
        console.print("[dim]Sending to Deepgram...[/dim]")

        response = httpx.post(
            "https://api.deepgram.com/v1/listen",
            params={
                "model": "nova-3",
                "language": "en",
                "punctuate": "true",
                "paragraphs": "true",
            },
            headers={
                "Authorization": f"Token {DEEPGRAM_API_KEY}",
                "Content-Type": "audio/ogg",
            },
            content=ogg_data,
            timeout=120,
        )

        if response.status_code != 200:
            console.print(f"[red]Deepgram error: {response.status_code}[/red]")
            console.print(response.text[:500])
            return

        result = response.json()

        # Debug: show structure
        channels = result.get("results", {}).get("channels", [])
        if not channels:
            console.print("[yellow]No channels in response[/yellow]")
            console.print(f"[dim]{result}[/dim]")
            return

        # Get transcript from first alternative
        alternatives = channels[0].get("alternatives", [])
        if not alternatives:
            console.print("[yellow]No alternatives in response[/yellow]")
            return

        transcript = alternatives[0].get("transcript", "")

        if transcript:
            console.print("\n[bold]Re-transcription:[/bold]\n")
            console.print(transcript)

            # Also show word-level if available
            words = alternatives[0].get("words", [])
            if words:
                console.print(f"\n[dim]({len(words)} words detected)[/dim]")

            # Save timestamp for --since-last
            set_last_retranscribe_time(end_us)
            console.print(f"[dim]Saved end time for --since-last[/dim]")
        else:
            console.print("[yellow]Empty transcript - possibly silence or no speech detected[/yellow]")

    except Exception as e:
        console.print(f"[red]Error: {e}[/red]")


@transcript.command("follow")
def transcript_follow():
    """Continuously print new transcripts as they arrive.

    Run this in a terminal to see live transcription output.
    Press Ctrl+C to stop.
    """
    import redis
    import signal
    import sys

    def handle_sigint(sig, frame):
        console.print("\n[dim]Stopped.[/dim]")
        sys.exit(0)

    signal.signal(signal.SIGINT, handle_sigint)

    r = redis.Redis(decode_responses=True)

    try:
        r.ping()
    except redis.ConnectionError:
        console.print("[red]Cannot connect to Redis. Is it running?[/red]")
        return

    console.print("[dim]Following transcripts... (Ctrl+C to stop)[/dim]\n")

    # Start from now
    last_id = "$"

    while True:
        try:
            # Block for up to 1 second waiting for new entries
            result = r.xread({"transcripts": last_id}, block=1000, count=100)

            if not result:
                continue

            for stream_name, entries in result:
                for entry_id, fields in entries:
                    last_id = entry_id

                    # Only show final transcripts
                    if fields.get("is_final") != "1":
                        continue

                    text = fields.get("transcript", "")
                    if not text:
                        continue

                    timestamp = fields.get("timestamp", "")
                    try:
                        dt = datetime.fromisoformat(timestamp.replace("Z", "+00:00"))
                        time_str = dt.strftime("%H:%M:%S")
                    except:
                        time_str = "??:??:??"

                    console.print(f"[dim]{time_str}[/dim] {text}")

        except redis.ConnectionError:
            console.print("[red]Lost connection to Redis, reconnecting...[/red]")
            import time
            time.sleep(1)
            r = redis.Redis(decode_responses=True)


